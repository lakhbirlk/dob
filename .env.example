# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dob
DB_USER=dob
DB_PASSWORD=dob

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (use a strong random string in production)
JWT_SECRET=changeme-change-me-change-me-change-me-change

# Razorpay (test keys)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxx

# Storage (minio for local dev, s3 for production)
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=dob-files

# AWS (when STORAGE_PROVIDER=s3)
AWS_REGION=ap-south-1
S3_BUCKET=dob-files
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# Server
SERVER_PORT=8080
CORS_ORIGINS=http://localhost:19006,http://localhost:8081
LOG_LEVEL=INFO
